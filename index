  const exDone   = new Set(all.map(function(r) { return r.exercise_id; })).size;
  statsEl.innerHTML =
    '<div class="stat-card"><div class="stat-label">Séances</div><div class="stat-val">'+dates.size+'</div><div class="stat-sub">enregistrées</div></div>'+
