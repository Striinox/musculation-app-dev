async function confirmReplace(e) {
  if (!replaceTarget || !activeProgram) return;
  const { dayIdx } = replaceTarget;
  const day = activeProgram.structure.days[dayIdx];
  const idx = day.exercises.findIndex(function(ex) { return ex.id === replaceTarget.exId; });
  if (idx === -1) return;
  day.exercises[idx] = {
    id:e.id, name:e.name, desc:e.description||'',
    category:e.category, rep:e.reps_recommended||'8-12',
    sets:day.exercises[idx].sets
  };
  await sb.from('programs').update({ structure:activeProgram.structure }).eq('id',activeProgram.id);
  closeModal();
  buildWorkoutPages();
  setSyncStatus('✓ Programme mis à jour','');
  setTimeout(function() { setSyncStatus('',''); }, 2000);
}

function closeModal() {
  document.getElementById('replace-modal').classList.remove('open');
  replaceTarget = null;
}

