  showScreen('onboarding');
  buildOnbDots(isExisting ? 7 : 5);
  showOnbStep(isExisting ? 0 : 1);
}

function buildOnbDots(n) {
  const el = document.getElementById('onb-dots');
  el.innerHTML = '';
  for (let i = 0; i < n; i++) {
    const d = document.createElement('div');
    d.className = 'onb-dot';
    el.appendChild(d);
  }
  updateOnbDots();
}

function updateOnbDots() {
  document.querySelectorAll('.onb-dot').forEach((d, i) => {
    d.classList.remove('active', 'done');
    if (i === onbStep) d.classList.add('active');
    else if (i < onbStep) d.classList.add('done');
  });
}

function showOnbStep(n) {
  document.querySelectorAll('.onb-step').forEach(s => s.classList.remove('active'));
  const el = document.getElementById('onb-step-' + n);
  if (el) el.classList.add('active');
  onbStep = n;
  updateOnbDots();
}

