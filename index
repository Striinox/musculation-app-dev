// ══════════════════════════════════════
async function saveLog(exId, dayKey, numSets, dayIdx) {
  if (!currentUser) return;
  const dateVal = document.getElementById('date-'+dayIdx)?.value || today();
  let exName = exId;
  libraryCache.forEach(function(e) { if (e.id === exId) exName = e.name; });
  if (activeProgram) activeProgram.structure.days.forEach(function(d) {
    d.exercises.forEach(function(e) { if (e.id === exId) exName = e.name; });
  });
  const rows = [];
  for (let s = 1; s <= numSets; s++) {
    const w = parseFloat(document.getElementById('w-'+exId+'-'+dayIdx+'-'+s)?.value) || 0;
    const r = parseInt(document.getElementById('r-'+exId+'-'+dayIdx+'-'+s)?.value)   || 0;
    if (w > 0 || r > 0) rows.push({
      user_id:currentUser.id, exercise_id:exId, exercise_name:exName,
      day_key:dayKey, session_date:dateVal, set_number:s, weight_kg:w, reps:r
    });
  }
  if (!rows.length) { alert('Remplis au moins une série.'); return; }
  setSyncStatus('Sauvegarde...', 'syncing');
  await sb.from('workout_logs').delete()
    .eq('user_id',currentUser.id).eq('exercise_id',exId).eq('session_date',dateVal);
  const { error } = await sb.from('workout_logs').insert(rows);
  if (error) { setSyncStatus('Erreur','error'); return; }
  setSyncStatus('✓ Synchronisé','');
  setTimeout(function() { setSyncStatus('',''); }, 2000);
  const conf = document.getElementById('conf-'+exId+'-'+dayIdx);
  if (conf) { conf.classList.add('show'); setTimeout(function() { conf.classList.remove('show'); }, 2500); }
  let exNameTimer = exId;
libraryCache.forEach(function(e) { if (e.id === exId) exNameTimer = e.name; });
if (activeProgram) activeProgram.structure.days.forEach(function(d) {
  d.exercises.forEach(function(e) { if (e.id === exId) exNameTimer = e.name; });
});
openTimer(exNameTimer, exId);
  const hist = document.getElementById('hist-'+exId+'-'+dayIdx);
  if (hist && hist.classList.contains('open')) loadHist(exId, dayIdx, hist);
}

