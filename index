(async function init() {
  try {
    // Lire la session depuis localStorage directement
    const storageKey = 'sb-rqymrinhvihfrlgklkfi-auth-token';
    const raw = localStorage.getItem(storageKey);
    if (raw) {
      const parsed = JSON.parse(raw);
      if (parsed && parsed.user) {
        currentUser = parsed.user;
        await initUserSession();
        return;
      }
    }
    // Fallback sur getSession
    const { data: { session } } = await sb.auth.getSession();
    if (session && session.user) {
      currentUser = session.user;
      await initUserSession();
    }
  } catch(e) {
    // init failed silently
  }
})();
// ══════════════════════════════════════
// INIT USER SESSION
// ══════════════════════════════════════
async function initUserSession() {
  if (isInitializing) { console.log('already initializing, skip'); return; }
  isInitializing = true;
  const { data: lib } = await sb.from('exercises_library').select('*').order('name');
  libraryCache = lib || [];

  const { data: profile, error: profileError } = await sb.from('user_profiles')
    .select('*').eq('user_id', currentUser.id).single();

  if (!profile) {
    const { data: logs } = await sb.from('workout_logs')
      .select('id').eq('user_id', currentUser.id).limit(1);
    startOnboarding(logs && logs.length > 0);
  } else {
    await loadActiveProgram();
    showScreen('app');
    initAppUI();
    appReady = true;
  }
    isInitializing = false;
