<!DOCTYPE html>
<html lang="fr">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<meta name="mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
<meta name="apple-mobile-web-app-title" content="Muscu">
<meta name="theme-color" content="#0f0f0f">
<title>Programme Musculation</title>
<script src="https://cdn.jsdelivr.net/npm/@supabase/supabase-js@2"></script>
<style>
@import url('https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Inter:wght@400;500;600&display=swap');
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
:root{
  --bg:#0f0f0f;--sur:#181818;--card:#1f1f1f;--brd:#2c2c2c;
  --acc:#C8F135;--txt:#efefef;--mut:#777;--red:#ff4d4d;
  --blue:#4da6ff;--green:#4dff9e;--orange:#ff9500;
  --safe-top:env(safe-area-inset-top);--safe-bot:env(safe-area-inset-bottom);
}
html,body{height:100%;overflow:hidden}
body{background:var(--bg);color:var(--txt);font-family:'Inter',sans-serif;font-size:14px;display:flex;flex-direction:column}
.screen{display:none;flex-direction:column;height:100%}
.screen.active{display:flex}
#auth-screen{align-items:center;justify-content:center;padding:24px;gap:20px}
.auth-logo{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:4px;color:var(--acc);line-height:1;text-align:center}
.auth-sub{font-size:11px;color:var(--mut);text-transform:uppercase;letter-spacing:2px;text-align:center;margin-top:-10px}
.auth-card{background:var(--sur);border:1px solid var(--brd);border-radius:12px;padding:22px;width:100%;max-width:360px;display:flex;flex-direction:column;gap:14px}
.auth-card-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--acc)}
.inp-group{display:flex;flex-direction:column;gap:5px}
.inp-group label{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--mut)}
.inp-group input{background:var(--bg);border:1px solid var(--brd);border-radius:6px;color:var(--txt);font-family:'Inter',sans-serif;font-size:15px;padding:10px 12px;outline:none;-webkit-appearance:none;transition:border-color .15s}
.inp-group input:focus{border-color:var(--acc)}
.btn-primary{background:var(--acc);color:#0f0f0f;border:none;border-radius:6px;padding:12px;font-family:'Inter',sans-serif;font-size:13px;font-weight:700;cursor:pointer;width:100%;transition:.15s}
.btn-primary:active{transform:scale(.98)}
.btn-secondary{background:none;border:1px solid var(--brd);border-radius:6px;padding:11px;font-family:'Inter',sans-serif;font-size:13px;color:var(--txt);cursor:pointer;width:100%}
.auth-switch{font-size:12px;color:var(--mut);text-align:center}
.auth-switch span{color:var(--acc);cursor:pointer;font-weight:600}
.auth-error{font-size:11px;color:var(--red);min-height:16px;text-align:center}
#onboarding-screen{padding:0}
.onb-wrap{flex:1;overflow-y:auto;padding:calc(var(--safe-top) + 20px) 20px 40px}
.onb-header{text-align:center;margin-bottom:28px}
.onb-logo{font-family:'Bebas Neue',sans-serif;font-size:36px;letter-spacing:3px;color:var(--acc)}
.onb-step-indicator{display:flex;gap:6px;justify-content:center;margin-top:12px}
.onb-dot{width:8px;height:8px;border-radius:50%;background:var(--brd);transition:.2s}
.onb-dot.active{background:var(--acc);width:20px;border-radius:4px}
.onb-dot.done{background:var(--acc);opacity:.4}
.onb-step{display:none}.onb-step.active{display:block}
.onb-question{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:1px;line-height:1.2;margin-bottom:6px}
.onb-hint{font-size:12px;color:var(--mut);margin-bottom:20px;line-height:1.5}
.onb-options{display:flex;flex-direction:column;gap:10px;margin-bottom:24px}
.onb-opt{background:var(--card);border:1px solid var(--brd);border-radius:10px;padding:14px 16px;cursor:pointer;transition:.15s;display:flex;align-items:center;gap:12px}
.onb-opt.selected{border-color:var(--acc);background:rgba(200,241,53,.06)}
.onb-opt-icon{font-size:24px;flex-shrink:0}
.onb-opt-text strong{display:block;font-size:14px;font-weight:600;margin-bottom:2px}
.onb-opt-text span{font-size:11px;color:var(--mut)}
.onb-days-grid{display:grid;grid-template-columns:repeat(5,1fr);gap:8px;margin-bottom:24px}
.onb-day-btn{background:var(--card);border:1px solid var(--brd);border-radius:8px;padding:14px 4px;text-align:center;cursor:pointer;transition:.15s}
.onb-day-btn.selected{border-color:var(--acc);background:rgba(200,241,53,.06)}
.onb-day-btn .day-num{font-family:'Bebas Neue',sans-serif;font-size:28px;color:var(--acc);line-height:1}
.onb-day-btn .day-lbl{font-size:10px;color:var(--mut)}
.onb-nav{display:flex;gap:10px;padding-bottom:20px}
.onb-existing-notice{background:rgba(200,241,53,.06);border:1px solid rgba(200,241,53,.2);border-radius:10px;padding:16px;margin-bottom:20px}
.onb-existing-notice p{font-size:12px;color:var(--mut);line-height:1.6;margin-bottom:12px}
.onb-existing-notice strong{color:var(--acc)}
#app-screen{overflow:hidden}
.app-header{background:var(--sur);border-bottom:2px solid var(--acc);padding:calc(var(--safe-top) + 8px) 16px 10px;display:flex;align-items:center;justify-content:space-between;flex-shrink:0}
.app-header h1{font-family:'Bebas Neue',sans-serif;font-size:26px;letter-spacing:3px;color:var(--acc);line-height:1}
.header-right{display:flex;align-items:center;gap:8px}
.prog-switcher{background:var(--card);border:1px solid var(--brd);border-radius:5px;padding:4px 10px;font-size:10px;color:var(--mut);cursor:pointer;font-family:'Inter',sans-serif;max-width:130px;overflow:hidden;text-overflow:ellipsis;white-space:nowrap}
.btn-logout{background:none;border:1px solid var(--brd);border-radius:4px;padding:4px 8px;font-size:10px;color:var(--mut);cursor:pointer;font-family:'Inter',sans-serif}
.app-content{flex:1;overflow-y:auto;overflow-x:hidden;-webkit-overflow-scrolling:touch}
.page{display:none;padding:16px 14px 24px}.page.on{display:block}
.bottom-nav{background:var(--sur);border-top:1px solid var(--brd);display:grid;padding-bottom:var(--safe-bot);flex-shrink:0}
.nav-btn{background:none;border:none;border-top:2px solid transparent;padding:8px 2px 6px;display:flex;flex-direction:column;align-items:center;gap:2px;cursor:pointer}
.nav-btn .ni{font-size:18px;line-height:1}
.nav-btn .nl{font-size:8px;font-weight:600;letter-spacing:.5px;text-transform:uppercase;color:var(--mut);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;width:100%;text-align:center}
.nav-btn.on{border-top-color:var(--acc)}.nav-btn.on .nl{color:var(--acc)}
.nav-btn.dash.on{border-top-color:var(--blue)}.nav-btn.dash.on .nl{color:var(--blue)}
.nav-btn.lib.on{border-top-color:var(--orange)}.nav-btn.lib.on .nl{color:var(--orange)}
.nav-btn.prg.on{border-top-color:var(--acc)}.nav-btn.prg.on .nl{color:var(--acc)}
.page-head{display:flex;align-items:center;gap:12px;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--brd)}
.page-num{font-family:'Bebas Neue',sans-serif;font-size:42px;color:var(--brd);line-height:1;flex-shrink:0}
.page-info h2{font-family:'Bebas Neue',sans-serif;font-size:20px;letter-spacing:2px;color:var(--acc);line-height:1.1}
.page-info p{color:var(--mut);font-size:10px;margin-top:2px}
.session-bar{display:flex;align-items:center;gap:10px;margin-bottom:14px;padding:10px 12px;background:var(--card);border:1px solid var(--brd);border-radius:8px;flex-wrap:wrap}
.session-bar label{font-size:10px;font-weight:600;color:var(--mut);text-transform:uppercase;letter-spacing:1px;white-space:nowrap}
.session-bar input[type=date]{background:var(--bg);border:1px solid var(--brd);border-radius:5px;color:var(--txt);font-family:'Inter',sans-serif;font-size:13px;padding:6px 10px;outline:none;-webkit-appearance:none;flex:1;min-width:0}
.session-bar input[type=date]:focus{border-color:var(--acc)}
.ex-card{background:var(--card);border:1px solid var(--brd);border-radius:10px;overflow:hidden;margin-bottom:14px}
.ex-vis{background:#111;border-bottom:1px solid var(--brd);display:flex;align-items:center;justify-content:center;padding:6px;height:140px}
.ex-vis svg{width:100%;height:100%;max-width:260px;display:block}
.ex-body{padding:12px 14px}
.ex-name{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px;margin-bottom:6px}
.ex-meta{display:flex;gap:6px;margin-bottom:8px;flex-wrap:wrap;align-items:center}
.ex-pill{background:rgba(200,241,53,.07);border:1px solid rgba(200,241,53,.2);border-radius:3px;padding:2px 8px;font-size:10px;font-weight:600;color:var(--acc)}
.ex-desc{font-size:11px;color:var(--mut);line-height:1.5;margin-bottom:10px}
.ex-replace-btn{background:none;border:1px solid var(--brd);border-radius:4px;padding:3px 8px;font-size:10px;color:var(--mut);cursor:pointer;font-family:'Inter',sans-serif;margin-left:auto}
.log-section{border-top:1px solid var(--brd);padding-top:10px}
.log-title{font-size:10px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--mut);margin-bottom:8px}
.set-rows{display:flex;flex-direction:column;gap:6px;margin-bottom:10px}
.set-row{display:grid;grid-template-columns:52px 1fr 14px 1fr;align-items:center;gap:6px}
.set-num{font-size:10px;font-weight:600;color:var(--mut)}
.set-row input{background:var(--bg);border:1px solid var(--brd);border-radius:5px;color:var(--txt);font-family:'Inter',sans-serif;font-size:14px;padding:7px 6px;outline:none;text-align:center;-webkit-appearance:none;transition:border-color .15s;width:100%}
.set-row input:focus{border-color:var(--acc)}
.set-row input::placeholder{color:#444;font-size:10px}
.set-sep{font-size:12px;color:var(--mut);text-align:center}
.log-actions{display:flex;gap:8px}
.btn-save{flex:1;background:var(--acc);color:#0f0f0f;border:none;border-radius:6px;padding:9px;font-family:'Inter',sans-serif;font-size:12px;font-weight:700;cursor:pointer}
.btn-save:active{transform:scale(.97)}
.btn-hist{background:none;border:1px solid var(--brd);border-radius:6px;padding:9px 12px;font-family:'Inter',sans-serif;font-size:11px;color:var(--mut);cursor:pointer;white-space:nowrap}
.save-confirm{font-size:10px;color:var(--green);margin-top:6px;min-height:14px;opacity:0;transition:opacity .3s}
.save-confirm.show{opacity:1}
.hist-panel{display:none;margin-top:10px;border-top:1px solid var(--brd);padding-top:10px}
.hist-panel.open{display:block}
.hist-entry{display:flex;align-items:flex-start;gap:8px;padding:6px 0;border-bottom:1px solid #1a1a1a}
.hist-entry:last-child{border-bottom:none}
.hist-date{font-size:10px;color:var(--mut);width:60px;flex-shrink:0;padding-top:2px}
.hist-sets{display:flex;flex-wrap:wrap;gap:4px;flex:1}
.hist-set{background:#252525;border-radius:3px;padding:2px 6px;font-size:10px}
.hist-set.pr{background:rgba(200,241,53,.12);border:1px solid rgba(200,241,53,.3);color:var(--acc)}
.hist-del{background:none;border:none;color:#3a3a3a;cursor:pointer;font-size:14px;padding:0 2px;line-height:1}
.hist-del:active{color:var(--red)}
.hist-empty{font-size:11px;color:#444;font-style:italic}
.dash-stats{display:grid;grid-template-columns:1fr 1fr;gap:10px;margin-bottom:20px}
.stat-card{background:var(--card);border:1px solid var(--brd);border-radius:8px;padding:14px}
.stat-label{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--mut);margin-bottom:4px}
.stat-val{font-family:'Bebas Neue',sans-serif;font-size:32px;letter-spacing:1px;line-height:1}
.stat-sub{font-size:9px;color:var(--mut);margin-top:2px}
.dash-filters{display:flex;gap:6px;overflow-x:auto;padding-bottom:2px;margin-bottom:16px;scrollbar-width:none}
.dash-filters::-webkit-scrollbar{display:none}
.flt-btn{background:var(--card);border:1px solid var(--brd);border-radius:5px;padding:5px 12px;font-size:10px;font-weight:600;letter-spacing:1px;color:var(--mut);cursor:pointer;text-transform:uppercase;white-space:nowrap;flex-shrink:0;font-family:'Inter',sans-serif}
.flt-btn.on{border-color:var(--blue);color:var(--blue);background:rgba(77,166,255,.08)}
.ex-chart-block{margin-bottom:20px;background:var(--card);border:1px solid var(--brd);border-radius:8px;overflow:hidden}
.ex-chart-head{padding:12px 14px 0;display:flex;align-items:center;justify-content:space-between;flex-wrap:wrap;gap:6px}
.ex-chart-name{font-family:'Bebas Neue',sans-serif;font-size:16px;letter-spacing:1px}
.ex-chart-pr{font-size:10px;color:var(--acc)}
.ex-chart-day{font-size:9px;font-weight:600;text-transform:uppercase;letter-spacing:1px;padding:2px 7px;border-radius:3px;background:rgba(200,241,53,.08);border:1px solid rgba(200,241,53,.2);color:var(--acc)}
.chart-area{padding:10px 14px 14px;overflow-x:auto}
.chart-area svg{display:block;width:100%;height:auto}
.dash-empty{text-align:center;padding:50px 20px;color:var(--mut)}
.dash-empty-icon{font-size:48px;display:block;margin-bottom:12px}
.lib-filters{display:flex;gap:8px;overflow-x:auto;padding-bottom:8px;margin-bottom:14px;scrollbar-width:none}
.lib-filters::-webkit-scrollbar{display:none}
.lib-filter{background:var(--card);border:1px solid var(--brd);border-radius:5px;padding:5px 12px;font-size:10px;font-weight:600;color:var(--mut);cursor:pointer;white-space:nowrap;flex-shrink:0;font-family:'Inter',sans-serif;text-transform:uppercase;letter-spacing:.5px}
.lib-filter.on{border-color:var(--orange);color:var(--orange);background:rgba(255,149,0,.08)}
.lib-search{background:var(--card);border:1px solid var(--brd);border-radius:8px;padding:10px 14px;font-family:'Inter',sans-serif;font-size:14px;color:var(--txt);outline:none;width:100%;margin-bottom:12px;-webkit-appearance:none}
.lib-search:focus{border-color:var(--orange)}
.lib-search::placeholder{color:#444}
.lib-grid{display:flex;flex-direction:column;gap:10px}
.lib-card{background:var(--card);border:1px solid var(--brd);border-radius:10px;overflow:hidden;display:flex;align-items:stretch}
.lib-card-vis{width:100px;min-height:80px;background:#111;display:flex;align-items:center;justify-content:center;flex-shrink:0;padding:6px}
.lib-card-vis svg{width:88px;height:60px;display:block}
.lib-card-body{padding:10px 12px;flex:1;min-width:0}
.lib-card-name{font-family:'Bebas Neue',sans-serif;font-size:15px;letter-spacing:1px;margin-bottom:4px}
.lib-card-muscle{font-size:10px;color:var(--mut);margin-bottom:6px}
.lib-card-tags{display:flex;gap:4px;flex-wrap:wrap}
.lib-tag{font-size:9px;padding:1px 6px;border-radius:10px;font-weight:600}
.lib-tag-push{background:rgba(77,166,255,.12);color:var(--blue)}
.lib-tag-pull{background:rgba(77,255,158,.12);color:var(--green)}
.lib-tag-legs{background:rgba(255,149,0,.12);color:var(--orange)}
.lib-tag-core{background:rgba(200,241,53,.1);color:var(--acc)}
.lib-tag-beginner{background:rgba(77,255,158,.1);color:var(--green)}
.lib-tag-intermediate{background:rgba(255,149,0,.1);color:var(--orange)}
.lib-tag-advanced{background:rgba(255,77,77,.1);color:var(--red)}
.prog-page-head{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:14px;border-bottom:1px solid var(--brd)}
.prog-list{display:flex;flex-direction:column;gap:10px;margin-bottom:20px}
.prog-card{background:var(--card);border:1px solid var(--brd);border-radius:10px;padding:14px 16px;display:flex;align-items:center;gap:12px}
.prog-card.active-prog{border-color:var(--acc)}
.prog-card-info{flex:1;min-width:0}
.prog-card-name{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:1px;margin-bottom:2px}
.prog-card-meta{font-size:10px;color:var(--mut)}
.prog-active-badge{background:rgba(200,241,53,.1);border:1px solid rgba(200,241,53,.3);border-radius:3px;padding:2px 7px;font-size:9px;font-weight:600;color:var(--acc);white-space:nowrap}
.prog-actions{display:flex;gap:6px}
.prog-action-btn{background:none;border:1px solid var(--brd);border-radius:4px;padding:5px 10px;font-size:10px;color:var(--mut);cursor:pointer;font-family:'Inter',sans-serif}
.btn-new-prog{background:rgba(200,241,53,.06);border:1px solid rgba(200,241,53,.2);border-radius:8px;padding:14px;text-align:center;cursor:pointer;font-size:13px;color:var(--acc);font-family:'Inter',sans-serif;font-weight:600;width:100%}
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.7);z-index:200;align-items:flex-end;justify-content:center}
.modal-overlay.open{display:flex}
.modal{background:var(--sur);border-radius:16px 16px 0 0;padding:20px;width:100%;max-height:80vh;overflow-y:auto;padding-bottom:calc(20px + var(--safe-bot))}
.modal-title{font-family:'Bebas Neue',sans-serif;font-size:22px;letter-spacing:2px;color:var(--acc);margin-bottom:4px}
.modal-sub{font-size:11px;color:var(--mut);margin-bottom:16px}
.modal-close{background:none;border:none;color:var(--mut);font-size:20px;cursor:pointer;float:right;margin-top:-4px}
.sync-status{font-size:10px;color:var(--mut);text-align:center;padding:4px;flex-shrink:0;min-height:20px}
.sync-status.syncing{color:var(--acc)}.sync-status.error{color:var(--red)}
.week-grid{display:grid;grid-template-columns:repeat(7,1fr);gap:6px;margin-bottom:28px}
.wday{background:var(--card);border:1px solid var(--brd);border-radius:6px;padding:10px 4px;text-align:center}
.wday .wn{font-size:8px;text-transform:uppercase;letter-spacing:1px;color:var(--mut);margin-bottom:4px}
.wday .wt{font-family:'Bebas Neue',sans-serif;font-size:12px;letter-spacing:1px;color:var(--acc)}
.wday.rest .wt{color:var(--mut)}
.tips-box{padding:18px;background:var(--card);border:1px solid var(--brd);border-left:3px solid var(--acc);border-radius:8px}
.tips-box h3{font-family:'Bebas Neue',sans-serif;font-size:17px;letter-spacing:2px;color:var(--acc);margin-bottom:10px}
.tips-grid{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.tip{display:flex;gap:8px}
.tip .ic{font-size:14px;flex-shrink:0;margin-top:1px}
.tip strong{display:block;font-size:11px;font-weight:600;margin-bottom:1px}
.tip span{font-size:10px;color:var(--mut)}
.timer-overlay{position:fixed;.timer-overlay{position:fixed;bottom:0;left:0;right:0;z-index:100;background:var(--sur);border-top:2px solid var(--acc);padding:16px 20px calc(16px + var(--safe-bot));display:none;flex-direction:column;gap:12px;pointer-events:none}
.timer-overlay.open{display:flex;pointer-events:all}bottom:0;left:0;right:0;z-index:100;background:var(--sur);border-top:2px solid var(--acc);padding:16px 20px calc(16px + var(--safe-bot));display:none;flex-direction:column;gap:12px}
.timer-overlay.open{display:flex}
.timer-header{display:flex;align-items:center;justify-content:space-between}
.timer-title{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--mut)}
.timer-skip{background:none;border:none;font-size:11px;color:var(--mut);cursor:pointer;font-family:'Inter',sans-serif}
.timer-display{font-family:'Bebas Neue',sans-serif;font-size:52px;letter-spacing:4px;color:var(--acc);text-align:center;line-height:1}
.timer-display.urgent{color:var(--red)}
.timer-options{display:grid;grid-template-columns:repeat(5,1fr);gap:6px}
.timer-opt{background:var(--card);border:1px solid var(--brd);border-radius:6px;padding:8px 4px;text-align:center;cursor:pointer;font-size:11px;font-weight:600;color:var(--mut);font-family:'Inter',sans-serif;transition:.15s}
.timer-opt.selected{border-color:var(--acc);color:var(--acc);background:rgba(200,241,53,.08)}
.timer-start{background:var(--acc);color:#0f0f0f;border:none;border-radius:8px;padding:12px;font-family:'Inter',sans-serif;font-size:13px;font-weight:700;cursor:pointer;width:100%}
.timer-bar{height:3px;background:var(--brd);border-radius:2px;overflow:hidden}
.timer-bar-fill{height:100%;background:var(--acc);transition:width 1s linear;width:100%}
.timer-bar-fill.urgent{background:var(--red)}
</style>
</head>
<body>

<!-- AUTH -->
<div id="auth-screen" class="screen active">
  <div class="auth-logo">💪 Muscu</div>
  <div class="auth-sub">Programme · Prise de Masse</div>
  <div class="auth-card" id="login-form">
