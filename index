// ══════════════════════════════════════
// TIMER DE REPOS
// ══════════════════════════════════════
let timerInterval  = null;
let timerRemaining = 0;
let timerTotal     = 0;
let timerRunning   = false;
let timerExId      = null;
const timerPrefs   = {};

function openTimer(exName, exId) {
  timerExId = exId;
  const lastSecs = timerPrefs[exId] || 90;
  document.querySelectorAll('.timer-opt').forEach(function(o) {
    o.classList.toggle('selected', parseInt(o.dataset.secs) === lastSecs);
  });
  document.getElementById('timer-ex-name').textContent  = exName + ' — Repos';
  document.getElementById('timer-display').textContent  = formatTime(lastSecs);
  document.getElementById('timer-display').classList.remove('urgent');
  document.getElementById('timer-display').style.fontSize = '';
  document.getElementById('timer-bar-fill').style.width = '100%';
  document.getElementById('timer-bar-fill').classList.remove('urgent');
  document.getElementById('timer-start').textContent = '▶ Démarrer le repos';
  document.getElementById('timer-start').disabled = false;
  timerRemaining = lastSecs;
  timerTotal     = lastSecs;
  timerRunning   = false;
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  document.getElementById('timer-overlay').classList.add('open');
}

function closeTimer() {
  document.getElementById('timer-overlay').classList.remove('open');
  if (timerInterval) { clearInterval(timerInterval); timerInterval = null; }
  timerRunning = false;
}

function formatTime(secs) {
  const m = Math.floor(secs / 60);
  const s = secs % 60;
  return m + ':' + (s < 10 ? '0' + s : s);
}

function startTimer() {
  if (timerRunning) return;
  timerRunning = true;
  const selectedOpt = document.querySelector('.timer-opt.selected');
  const secs = parseInt(selectedOpt ? selectedOpt.dataset.secs : 90);
  if (timerExId) timerPrefs[timerExId] = secs;
  timerRemaining = secs;
  timerTotal     = secs;
  document.getElementById('timer-start').textContent = '⏸ En cours...';
  document.getElementById('timer-start').disabled = true;
  document.getElementById('timer-display').textContent = formatTime(timerRemaining);
  document.getElementById('timer-bar-fill').style.width = '100%';

  timerInterval = setInterval(function() {
    timerRemaining--;
    const display = document.getElementById('timer-display');
    const barFill = document.getElementById('timer-bar-fill');
    const pct     = (timerRemaining / timerTotal) * 100;
    display.textContent    = formatTime(timerRemaining);
    barFill.style.width    = pct + '%';
    if (timerRemaining <= 10) {
      display.classList.add('urgent');
      barFill.classList.add('urgent');
    }
    if (timerRemaining <= 0) {
      clearInterval(timerInterval);
      timerInterval = null;
      timerRunning  = false;
      display.textContent  = "C'est reparti ! 💪";
      display.style.fontSize = '24px';
      if (navigator.vibrate) navigator.vibrate([200, 100, 200]);
      setTimeout(function() { closeTimer(); }, 2000);
    }
  }, 1000);
}
  
window.startTimer = startTimer;
window.closeTimer = closeTimer;
window.openTimer  = openTimer;

  window.selectTimerOpt = function(el) {
  if (timerRunning) return;
  document.querySelectorAll('.timer-opt').forEach(function(o) { o.classList.remove('selected'); });
  el.classList.add('selected');
  const secs = parseInt(el.dataset.secs);
  timerRemaining = secs;
  timerTotal     = secs;
  document.getElementById('timer-display').textContent = formatTime(secs);
  document.getElementById('timer-bar-fill').style.width = '100%';
};
})();
