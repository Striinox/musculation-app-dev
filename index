    '<div class="stat-card"><div class="stat-label">Exercices</div><div class="stat-val">'+exDone+'</div><div class="stat-sub">suivis</div></div>';
  const filtersEl = document.getElementById('dash-filters');
  const dayKeys   = (activeProgram && activeProgram.structure.days || []).map(function(d) { return d.key; });
  filtersEl.innerHTML =
    '<button class="flt-btn'+(dashFilter==='all'?' on':'')+'" data-filter="all">Tout</button>' +
    dayKeys.map(function(k) { return '<button class="flt-btn'+(dashFilter===k?' on':'')+'" data-filter="'+k+'">'+k+'</button>'; }).join('');
  const chartsEl = document.getElementById('dash-charts');
  if (!filtered.length) {
    chartsEl.innerHTML = '<div class="dash-empty"><span class="dash-empty-icon">📭</span>Aucune donnée.<br>Commence à sauvegarder tes séries !</div>';
    return;
  }
  const byEx = {};
  filtered.forEach(function(r) { if (!byEx[r.exercise_id]) byEx[r.exercise_id]=[]; byEx[r.exercise_id].push(r); });
  let html = '';
  Object.entries(byEx).forEach(function([id, rows]) {
    const byDate = {};
    rows.forEach(function(r) {
      if (!byDate[r.session_date]) byDate[r.session_date]={maxW:0,vol:0,best1rm:0};
      byDate[r.session_date].maxW    = Math.max(byDate[r.session_date].maxW, r.weight_kg||0);
      byDate[r.session_date].vol    += (r.weight_kg||0)*(r.reps||0);
      byDate[r.session_date].best1rm = Math.max(byDate[r.session_date].best1rm, (r.weight_kg||0)*(1+(r.reps||0)/30));
    });
    const pts    = Object.entries(byDate).sort(function(a,b){return a[0].localeCompare(b[0]);}).map(function([d,v]){return Object.assign({date:d},v);});
    const pr     = Math.max.apply(null, pts.map(function(p){return p.best1rm;}));
    const exName = rows[0].exercise_name||id;
    const dk     = rows[0].day_key||'';
    html +=
      '<div class="ex-chart-block">' +
        '<div class="ex-chart-head">' +
          '<span class="ex-chart-name">'+exName+'</span>' +
          '<span class="ex-chart-day">'+dk+'</span>' +
          (pr>0?'<span class="ex-chart-pr">🏆 PR ~'+Math.round(pr*10)/10+'kg</span>':'') +
        '</div>' +
        '<div class="chart-area">'+buildChart(pts)+'</div>' +
      '</div>';
  });
  chartsEl.innerHTML = html;
}

function buildChart(pts) {
  const vals = pts.map(function(p){return p.maxW;}).filter(function(v){return v>0;});
  if (!vals.length) return '<p style="font-size:11px;color:#444;padding:8px 0;font-style:italic">Sauvegarde un poids pour voir le graphique.</p>';
  const W=320,H=110,pL=36,pR=10,pT=12,pB=26,iW=W-pL-pR,iH=H-pT-pB;
  const minV=Math.min.apply(null,vals)*.9, maxV=Math.max.apply(null,vals)*1.1, range=maxV-minV||1, n=pts.length;
  const ptCoords=pts.map(function(p,i){return{x:pL+(n>1?i*iW/(n-1):iW/2),y:p.maxW>0?pT+iH-((p.maxW-minV)/range)*iH:null,p:p};}).filter(function(c){return c.y!==null;});
  if (!ptCoords.length) return '';
  let grid='',labels='';
  [0,.5,1].forEach(function(t){
    const yy=pT+t*iH, val=maxV-t*range;
    grid   +='<line x1="'+pL+'" y1="'+yy.toFixed(1)+'" x2="'+(W-pR)+'" y2="'+yy.toFixed(1)+'" stroke="#222" stroke-width="1"/>';
    labels +='<text x="'+(pL-3)+'" y="'+(yy+4).toFixed(1)+'" text-anchor="end" font-size="8" fill="#555" font-family="Inter,sans-serif">'+Math.round(val)+'</text>';
  });
  const path=ptCoords.map(function(c,i){return(i?'L':'M')+c.x.toFixed(1)+' '+c.y.toFixed(1);}).join(' ');
  const area='M'+ptCoords[0].x+' '+(pT+iH)+' '+ptCoords.map(function(c){return'L'+c.x.toFixed(1)+' '+c.y.toFixed(1);}).join(' ')+' L'+ptCoords[ptCoords.length-1].x+' '+(pT+iH)+' Z';
  const maxW=Math.max.apply(null,pts.map(function(p){return p.maxW;}));
  let dots='',xlab='';
  const step=Math.max(1,Math.ceil(ptCoords.length/5));
  ptCoords.forEach(function(c,i){
    const isPR=c.p.maxW===maxW;
    dots+='<circle cx="'+c.x.toFixed(1)+'" cy="'+c.y.toFixed(1)+'" r="'+(isPR?5:3.5)+'" fill="'+(isPR?'#C8F135':'#4da6ff')+'" stroke="#111" stroke-width="1.5"/>';
    if(i%step===0||i===ptCoords.length-1){const d=c.p.date.split('-');xlab+='<text x="'+c.x.toFixed(1)+'" y="'+(H-4)+'" text-anchor="middle" font-size="7" fill="#555" font-family="Inter,sans-serif">'+d[2]+'/'+d[1]+'</text>';}
  });
  return '<svg viewBox="0 0 '+W+' '+H+'" style="width:100%;min-width:280px"><defs><linearGradient id="gc" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#4da6ff" stop-opacity="0.2"/><stop offset="100%" stop-color="#4da6ff" stop-opacity="0"/></linearGradient></defs>'+grid+labels+'<path d="'+area+'" fill="url(#gc)"/><path d="'+path+'" fill="none" stroke="#4da6ff" stroke-width="1.8" stroke-linejoin="round" stroke-linecap="round"/>'+dots+xlab+'<text x="'+pL+'" y="'+(pT-1)+'" font-size="7" fill="#555" font-family="Inter,sans-serif">kg max</text></svg>';
}

