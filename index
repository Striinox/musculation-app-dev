// HISTORY
// ══════════════════════════════════════
async function toggleHist(uid) {
  const panel = document.getElementById('hist-'+uid);
  if (!panel) return;
  if (panel.classList.contains('open')) { panel.classList.remove('open'); return; }
  panel.classList.add('open');
  const parts  = uid.split('-');
  const dayIdx = parts[parts.length-1];
  const exId   = parts.slice(0, parts.length-1).join('-');
  loadHist(exId, dayIdx, panel);
}

async function loadHist(exId, dayIdx, panel) {
  if (!panel || !currentUser) return;
  panel.innerHTML = '<div style="font-size:11px;color:var(--mut)">Chargement...</div>';
  const { data } = await sb.from('workout_logs').select('*')
    .eq('user_id',currentUser.id).eq('exercise_id',exId)
    .order('session_date',{ascending:false}).order('set_number',{ascending:true});
  if (!data || !data.length) { panel.innerHTML='<p class="hist-empty">Aucune donnée encore.</p>'; return; }
  const byDate = {};
  data.forEach(function(r) { if (!byDate[r.session_date]) byDate[r.session_date]=[]; byDate[r.session_date].push(r); });
  let bestEst = 0;
  data.forEach(function(r) { const e=r.weight_kg*(1+r.reps/30); if(e>bestEst) bestEst=e; });
  let html = '';
  Object.entries(byDate).forEach(function([date, rows]) {
    const dd = date.split('-').reverse().join('/');
    const sh = rows.map(function(r) {
      if (!r.weight_kg && !r.reps) return '';
      const est = r.weight_kg*(1+r.reps/30);
      const pr  = Math.abs(est-bestEst)<0.5 && est>0;
      return '<span class="hist-set'+(pr?' pr':'')+'">'+r.weight_kg+'kg×'+r.reps+'</span>';
    }).join('');
    if (!sh) return;
    html += '<div class="hist-entry"><span class="hist-date">'+dd+'</span><div class="hist-sets">'+sh+'</div><button class="hist-del" data-exid="'+exId+'" data-date="'+date+'" data-dayidx="'+dayIdx+'">✕</button></div>';
  });
  panel.innerHTML = html || '<p class="hist-empty">Aucune donnée.</p>';
  panel.querySelectorAll('.hist-del').forEach(function(btn) {
    btn.addEventListener('click', function() { deleteLog(this.dataset.exid, this.dataset.date, this.dataset.dayidx); });
  });
}

async function deleteLog(exId, date, dayIdx) {
  if (!confirm('Supprimer la séance du '+date.split('-').reverse().join('/')+' ?')) return;
  await sb.from('workout_logs').delete()
    .eq('user_id',currentUser.id).eq('exercise_id',exId).eq('session_date',date);
  const panel = document.getElementById('hist-'+exId+'-'+dayIdx);
  if (panel) loadHist(exId, dayIdx, panel);
}

